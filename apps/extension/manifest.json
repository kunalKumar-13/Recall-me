{
  "manifest_version": 3,
  "name": "Recall — Continuity Companion",
  "short_name": "Recall",
  "version": "2.1.0",
  "description": "A small memory surface for your browser. See the work you can step back into — locally, on your machine. Activity goes only to the local Recall daemon. Nothing leaves the device.",
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "webNavigation"
  ],
  "host_permissions": [
    "http://127.0.0.1:4545/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/16.png",
    "32": "icons/32.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  },
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Recall — Continuity Companion",
    "default_icon": {
      "16": "icons/16.png",
      "32": "icons/32.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  }
}
