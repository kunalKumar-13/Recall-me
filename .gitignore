# Python
__pycache__/
*.py[cod]
*.pyd
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
dist/
build/

# Local DB & cache (never commit user index or transient daemon state)
app/db/chroma_store/
.recall/
.recall.dev-backup/

# Node / extension build artifacts
node_modules/
apps/extension/ui/node_modules/
apps/admin/web/node_modules/
apps/admin/web/.next/

# IDE
.idea/
.vscode/
*.swp
.DS_Store
Thumbs.db

# Claude Code local, machine-specific settings (permission allowlist, etc.) — never shared
.claude/settings.local.json

# Demo media — large; produced artifacts live in releases/ or CDN
demo/*.mp4
demo/*.mov
demo/*.gif

# Logs (transient runtime; build_logs/ keeps named evidence files
# that ARE tracked - see docs/trust/INSTALL_PROOF_WINDOWS.md)
*.log.tmp
*.runtime.log
